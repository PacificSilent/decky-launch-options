{
  "name": "decky-launch-options",
  "version": "1.1.0",
  "description": "Decky plugin to inject launch options (e.g. ~/lsfg %command%) into Steam and non-Steam apps",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "node --experimental-strip-types --test src/launchOptions.test.ts"
  },
  "keywords": [
    "decky",
    "steam-deck",
    "launch-options",
    "lsfg"
  ],
  "author": "PacificSilent",
  "license": "MIT",
  "devDependencies": {
    "@decky/api": "^1.1.3",
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "rollup": "^4.24.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "react-icons": "^5.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
