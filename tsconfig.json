{
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "target": "ES2020",
    "jsx": "react-jsx",
    "declaration": false,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
